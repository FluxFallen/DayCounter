{
	"schemaVersion": 1,
	"id": "daycounter",
	"version": "${version}",
	"name": "Day Counter",
	"description": "Displays the current Minecraft day with a movable HUD.",
	"authors": [
		"Flux"
	],
	"contact": {
		"sources": "https://github.com/FluxFallen/DayCounter",
		"issues": "https://github.com/FluxFallen/DayCounter/issues"
	},
	"license": "MIT",
	"icon": "assets/daycounter/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.flux.daycounter.Daycounter"
		],
		"client": [
			"com.flux.daycounter.client.DayCounterClient"
		]
	},
	"mixins": [
		"daycounter.mixins.json",
		{
			"config": "daycounter.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": ">=26.1 <26.2",
		"java": ">=25",
		"fabric-api": "*"
	}
}